{
  "name": "kiro-cortex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "bun": "1.3.10"
  },
  "scripts": {
    "start": "bun src/mcp.ts",
    "build": "tsc",
    "check": "pnpm run --reporter=append-only --reporter-hide-prefix '/^check:.*$/'",
    "check:tsc": "tsc --noEmit",
    "check:els": "effect-language-service diagnostics --project tsconfig.json"
  },
  "dependencies": {
    "@effect/ai": "0.34.0",
    "@effect/platform": "0.95.0",
    "@effect/platform-bun": "0.88.0",
    "@effect/platform-node": "0.105.0",
    "@effect/sql": "0.50.0",
    "@effect/sql-pg": "0.51.0",
    "@langchain/langgraph": "1.2.2",
    "@langchain/langgraph-checkpoint-postgres": "1.0.1",
    "effect": "3.20.0",
    "pg": "8.20.0",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@effect/language-service": "0.80.0",
    "@types/bun": "1.3.10",
    "@types/pg": "8.18.0",
    "typescript": "5.9.3"
  }
}
